# ═══════════════════════════════════════════════
# EchelonHD Scanner Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# VPN (IPVanish)
VPN_USER=your_ipvanish_email
VPN_PASS=your_ipvanish_password
VPN_COUNTRY=Netherlands

# Media Path (root of your Plex/TrueNAS library)
# Should contain: Movies/, Shows/, Anime/ subdirectories
MEDIA_PATH=/mnt/Media/MediaServer

# EchelonHD
TRACKER_URL=https://echelonhd.me
TRACKER_PASSKEY=your_passkey_here

# TMDB
TMDB_API_KEY=93889655f8028098b115e8aa5e3f4414

# qBittorrent (non-standard port to avoid conflict with existing qBit)
QBIT_USER=admin
QBIT_PASS=adminadmin
QBIT_PORT=6891
BT_PORT=46213

# Dashboard
DASHBOARD_PORT=9090

# Scanner (0 = manual only, 3600 = hourly, 86400 = daily)
SCAN_INTERVAL=0

# System (TrueNAS default: 568 for apps)
PUID=568
PGID=568
TZ=America/New_York
