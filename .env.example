# ═══════════════════════════════════════════════
# EchelonHD Scanner Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════

# VPN (IPVanish)
VPN_USER=your_ipvanish_email
VPN_PASS=your_ipvanish_password
VPN_COUNTRY=Netherlands

# Media Paths (your Plex/TrueNAS library)
MOVIES_PATH=/mnt/Media/MediaServer/Movies
SHOWS_PATH=/mnt/Media/MediaServer/Shows
ANIME_PATH=/mnt/Media/MediaServer/Anime

# EchelonHD
TRACKER_URL=https://echelonhd.me
TRACKER_PASSKEY=your_passkey_here
TRACKER_API_ENDPOINT=https://echelonhd.me/upload-manager.php
TRACKER_API_PASSWORD=EchelonHD20261234!!

# TMDB
TMDB_API_KEY=93889655f8028098b115e8aa5e3f4414

# qBittorrent (inside the container)
QBIT_USER=admin
QBIT_PASS=adminadmin
QBIT_PORT=8080

# Dashboard
DASHBOARD_PORT=9090

# Scanner (0 = manual only, 3600 = hourly, 86400 = daily)
SCAN_INTERVAL=0

# System
PUID=1000
PGID=1000
TZ=America/New_York
